const fetch = require('node-fetch');

exports.handler = async (event) => {
  if (event.httpMethod !== 'POST') {
    return { statusCode: 405, body: 'Method Not Allowed' };
  }

  const authHeader = event.headers['authorization'];
  if (!authHeader) {
    return { statusCode: 401, body: 'Unauthorized' };
  }

  let body;
  try {
    body = JSON.parse(event.body);
  } catch {
    return { statusCode: 400, body: 'Invalid JSON' };
  }

  const { room_name, title } = body;
  if (!room_name) {
    return { statusCode: 400, body: 'room_name required' };
  }

  try {
    const response = await fetch('https://api.daily.co/v1/rooms', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${process.env.DAILY_API_KEY}`
      },
      body: JSON.stringify({
        name: room_name,
        properties: {
          max_participants: 10,
          enable_recording: 'cloud',
          exp: Math.floor(Date.now() / 1000) + (60 * 60 * 4), // 4 hour expiry
          enable_chat: true,
          enable_knocking: false,
          start_video_off: false,
          start_audio_off: false
        }
      })
    });

    if (!response.ok) {
      const err = await response.text();
      console.error('Daily API error:', err);
      return { statusCode: 500, body: 'Failed to create room' };
    }

    const room = await response.json();

    return {
      statusCode: 200,
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        room_name: room.name,
        room_url: room.url
      })
    };

  } catch (err) {
    console.error('create-room error:', err);
    return { statusCode: 500, body: 'Server error' };
  }
};
